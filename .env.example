# Database (Neon PostgreSQL)
DATABASE_URL=

# Better Auth (auto-read by Better Auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Client-side auth base URL (inlined at build time)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App secrets
APP_SECRET=

# Neon Auth (optional)
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=
BETTER_AUTH_API_KEY=

# Maintenance mode (set to "true" to enable)
MAINTENANCE_MODE=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" to show the Google sign-in button on login/register pages
# Must also set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET above
NEXT_PUBLIC_GOOGLE_ENABLED=false
